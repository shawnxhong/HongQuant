# Copy to .env and fill in; .env is gitignored.

# ---- Runtime ----
HONGQUANT_ENV=dev                     # dev | prod
HONGQUANT_DATA_DIR=./data             # Parquet data lake root
HONGQUANT_LOG_LEVEL=INFO

# ---- Alpaca (US equities OHLCV) ----
# Free with brokerage or market-data account: https://alpaca.markets/
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_PAPER=true                     # true -> paper; false -> live

# ---- Interactive Brokers (options chain + live) ----
# Requires TWS or IB Gateway running locally or on VPS
IBKR_HOST=127.0.0.1
IBKR_PORT=7497                        # 7497 paper TWS, 7496 live TWS, 4002 gateway paper, 4001 gateway live
IBKR_CLIENT_ID=17

# ---- SEC EDGAR ----
# EDGAR requires a User-Agent with contact info per their fair-access policy
EDGAR_USER_AGENT="HongQuant research youremail@example.com"

# ---- FRED (macro) ----
FRED_API_KEY=

# ---- Crypto exchanges (ccxt) ----
# Only keep the ones you actually use; leave blank for public market-data only
BINANCE_API_KEY=
BINANCE_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
COINBASE_API_KEY=
COINBASE_API_SECRET=

# ---- Optional paid data ----
POLYGON_API_KEY=
FMP_API_KEY=
FINNHUB_API_KEY=
TIINGO_API_KEY=

# ---- LLM providers ----
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# ---- Telegram notifications ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Postgres (elsewhere-stored metadata) ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=hongquant
POSTGRES_USER=hongquant
POSTGRES_PASSWORD=hongquant
